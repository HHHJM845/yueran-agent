# Runtime
NODE_ENV=development
APP_ENV=local

# Data layer: Supabase Postgres
DATABASE_PROVIDER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use the Supabase Postgres connection string from Dashboard -> Project Settings -> Database.
# Prefer the pooled connection for deployed serverless/web processes.
DATABASE_URL=PASTE_SUPABASE_POSTGRES_CONNECTION_STRING_HERE

# Background worker. Default 3 concurrent jobs; keep this conservative if provider rate limits are low.
JOB_WORKER_CONCURRENCY=3

# Asset storage: Aliyun OSS
ASSET_STORAGE_PROVIDER=aliyun_oss
ALIYUN_OSS_REGION=oss-cn-shenzhen
ALIYUN_OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
ALIYUN_OSS_BUCKET=augc-flow
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=

# AI provider routing
TEXT_STRUCTURING_PROVIDER=volcengine_ark
SPEECH_TRANSCRIPTION_PROVIDER=volcengine_ark
IMAGE_VIDEO_UNDERSTANDING_PROVIDER=volcengine_ark
ATMOSPHERE_IMAGE_PROVIDER=openai
VIDEO_GENERATION_PROVIDER=volcengine_ark
MATERIAL_EMBEDDING_PROVIDER=volcengine_ark

# Volcengine Ark / Doubao
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_STRUCTURING_MODEL=doubao-seed-2-1-pro-260628
ARK_SPEECH_TRANSCRIPTION_MODEL=doubao-seed-2-0-mini
ARK_IMAGE_VIDEO_UNDERSTANDING_MODEL=doubao-seed-2-0-lite-260215
ARK_VIDEO_GENERATION_MODEL=doubao-seedance-1-5-pro-251215
ARK_MATERIAL_EMBEDDING_MODEL=doubao-embedding-vision-251215

# OpenAI-compatible image generation relay
OPENAI_API_KEY=
OPENAI_BASE_URL=https://new.suxi.ai/v1
OPENAI_IMAGE_MODEL=gpt-image-2

# Feishu delivery
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DEFAULT_TENANT_KEY=

# Internal auth
SESSION_COOKIE_NAME=augc_session
SESSION_TTL_DAYS=14

# Optional only when running `npm run user:create`
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
ADMIN_ROLE=admin

# Contract and proposal exports
EXPORT_PROVIDER=local
PDF_EXPORT_ENABLED=true
WORD_EXPORT_ENABLED=true
